<IfModule mod_rewrite.c>
	RewriteEngine On

	# Force HTTPS (exclude cPanel validation)
	RewriteCond %{HTTPS} !=on
	RewriteCond %{REQUEST_URI} !^/[0-9]+\..+\.cpaneldcv$
	RewriteCond %{REQUEST_URI} !^/\.well-known/pki-validation/[A-F0-9]{32}\.txt(?:\ Comodo\ DCV)?$
	RewriteRule ^ https://%{HTTP_HOST}%{REQUEST_URI} [L,R=301]

	# Remove www prefix
	RewriteCond %{HTTP_HOST} ^www\.(.+)$ [NC]
	RewriteRule ^(.*)$ https://%1/$1 [R=301,L]

	# If your cPanel document root is public_html (project root), forward all requests to /public
	RewriteRule ^$ public/ [L]
	RewriteCond %{REQUEST_URI} !^/public/
	RewriteRule ^(.*)$ public/$1 [L]
</IfModule>

# Security Headers
<IfModule mod_headers.c>
	# Prevent clickjacking attacks
	Header always set X-Frame-Options "SAMEORIGIN"

	# Enable XSS protection
	Header always set X-XSS-Protection "1; mode=block"

	# Prevent MIME-type sniffing
	Header always set X-Content-Type-Options "nosniff"

	# Referrer policy
	Header always set Referrer-Policy "strict-origin-when-cross-origin"
</IfModule>

# Disallow directory listing at the project root
Options -Indexes

# Block access to sensitive files and directories
<FilesMatch "^(\..+|composer\.(json|lock)|package(-lock)?\.json|phpunit\.xml|artisan|\.env.*|webpack\.mix\.js|vite\.config\.js|README\.md|SECURITY_HARDENING\.md)$">
	Require all denied
</FilesMatch>

# Prevent PHP execution in uploads/storage directories
<DirectoryMatch "^.*(storage|uploads|cache|temp).*$">
	<FilesMatch "\.php$">
		Require all denied
	</FilesMatch>
</DirectoryMatch>


